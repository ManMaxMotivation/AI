{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "analysis",
    "algorithm",
    "automated_checks",
    "manual_checks",
    "assumptions",
    "limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "analysis": {
      "type": "object",
      "required": ["summary", "scope", "risks"],
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "mitigation"],
            "additionalProperties": false,
            "properties": {
              "risk": {"type": "string", "minLength": 1},
              "mitigation": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "algorithm": {
      "type": "object",
      "required": ["steps", "evidence"],
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "automated_checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    },
    "manual_checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "purpose", "expected"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z]+-[0-9]{3}$"},
        "purpose": {"type": "string", "minLength": 1},
        "expected": {"type": "string", "minLength": 1}
      }
    }
  }
}
